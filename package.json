{
  "name": "axiom-commerce-lab",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write .",
    "clean": "git clean -xdf node_modules .next dist coverage",
    "db:generate": "pnpm --filter @axiom/db db:generate",
    "db:migrate": "pnpm --filter @axiom/db db:migrate",
    "db:studio": "pnpm --filter @axiom/db db:studio",
    "db:seed": "pnpm --filter @axiom/db db:seed"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "latest",
    "prettier": "latest"
  }
}
